# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional overrides — accuracy-first strategy: start with the most capable
# model, then downshift once the eval (scripts/eval.py) shows a cheaper tier
# holds accuracy. Needs vision + PDF file input + structured outputs.
OPENAI_MODEL=gpt-5.6

# Downshift document extraction independently of assessment, e.g.:
# OPENAI_EXTRACTION_MODEL=gpt-4o

# Where the dataset lives (defaults to ./data)
# DATA_DIR=./data
